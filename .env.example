# Copier vers .env (NON commité) sur le serveur, à côté de docker-compose.yml.
#   cp .env.example .env  &&  nano .env

# Origine autorisée (CORS). Frontend et API étant sur le même sous-domaine, c'est
# surtout par sécurité. Mettre l'URL publique de fingec.
FRONTEND_ORIGINS=https://app.fingec.fr

# Secret de signature des jetons de session (JWT). OBLIGATOIRE en prod : sans lui,
# un secret éphémère est généré et les sessions sont invalidées à chaque redémarrage.
# Générer : openssl rand -hex 32
AUTH_SECRET=

# Admin initial — créé UNIQUEMENT au tout premier démarrage si la base est vide.
# Une fois le compte créé, les utilisateurs se gèrent dans l'app (page Admin).
ADMIN_EMAIL=admin@fingec.fr
ADMIN_PASSWORD=

# ── n8n (hébergé dans la stack fingec) ──────────────────────────────────────
# URL interne du conteneur n8n. Le frontend appelle /n8n/... → le backend vérifie
# le JWT puis relaie ici. Laisser la valeur par défaut sauf si tu renommes le conteneur.
N8N_BASE_URL=http://fingec-n8n:5678

# Sous-domaine de l'éditeur n8n (DNS A requis → IP du VPS).
N8N_HOST=n8n.fingec.fr

# URL publique des webhooks de production (passent par le dashboard authentifié).
WEBHOOK_URL=https://app.fingec.fr/n8n/

# Clé de chiffrement des credentials n8n — OBLIGATOIRE et STABLE (ne pas changer
# après coup, sinon les credentials enregistrés deviennent illisibles).
# Générer : openssl rand -hex 32
N8N_ENCRYPTION_KEY=
