# Copier vers /opt/fingec/backend/.env (NON commité) et remplir.
#
#   cp deploy/.env.example backend/.env
#   # puis générer un token : openssl rand -hex 32

# Jeton requis pour les actions admin (effacer les logs). Sans lui, la route est désactivée.
ADMIN_TOKEN=

# Origines autorisées (CORS). Inutile si frontend + API sont sur le même sous-domaine,
# mais on le renseigne par sécurité.
FRONTEND_ORIGINS=https://fingec.example.com

# Répertoire des données persistantes (logs.json, exports). Doit exister et être
# accessible en écriture par l'utilisateur du service systemd.
BACKEND_DATA_DIR=/opt/fingec/data
