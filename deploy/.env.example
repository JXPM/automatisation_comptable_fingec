# Copier vers /opt/fingec/.env (NON commité, à côté de docker-compose.yml) et remplir.
#
#   cp deploy/.env.example .env

# Secret de signature des jetons de session (JWT). OBLIGATOIRE en prod.
#   openssl rand -hex 32
AUTH_SECRET=

# Admin initial — créé UNIQUEMENT au tout premier démarrage (base vide).
ADMIN_EMAIL=admin@fingec.fr
ADMIN_PASSWORD=

# ── n8n (hébergé dans la stack fingec) ──────────────────────────────────────
# URL interne du conteneur n8n. Le frontend appelle /n8n/... → le backend vérifie
# le JWT puis relaie ici.
N8N_BASE_URL=http://fingec-n8n:5678

# Sous-domaine de l'éditeur n8n (DNS A requis → IP du VPS).
N8N_HOST=n8n.fingec.fr

# URL publique des webhooks de production (passent par le dashboard authentifié).
WEBHOOK_URL=https://app.fingec.fr/n8n/

# Clé de chiffrement des credentials n8n — OBLIGATOIRE et STABLE.
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Origines autorisées (CORS). Inutile si frontend + API sont sur le même sous-domaine,
# mais on le renseigne par sécurité.
FRONTEND_ORIGINS=https://app.fingec.fr
